# Copy to scripts/.env and fill in your settings
# cp scripts/.env.example scripts/.env

# ── Optionsdepth Authentication ────────────────────
# "google" = Google SSO (opens browser for manual sign-in)
# "email"  = email + password (auto-fills login form)
LOGIN_METHOD=google

# Email/password — only needed if LOGIN_METHOD=email
# OD_EMAIL=your@email.com
# OD_PASSWORD=yourpassword

# ── Chrome Profile ─────────────────────────────────
# Auto-detected on macOS/Linux/Windows. Override if needed.
# CHROME_PROFILE_PATH=

# ── Schwab API (optional) ──────────────────────────
# Provides auto-fetched SPX spot, VIX, and Expected Move.
# Without Schwab, falls back to 0dtespx.com scraping.
#
# Setup:
#   1. Register at developer.schwab.com
#   2. Fill in the values below
#   3. Run: npx schwab-authorize
#   4. Copy the SCHWAB_REFRESH_TOKEN value
#
# SCHWAB_APP_KEY=
# SCHWAB_SECRET=
# SCHWAB_CALLBACK_URL=https://127.0.0.1:5556
# SCHWAB_REFRESH_TOKEN=

# ── Data Settings ──────────────────────────────────
# Strike range is auto-computed from spot ± 2×EM.
# Override with these if needed:
# STRIKE_FLOOR=6700
# STRIKE_CEIL=7000

# Override spot/EM if auto-fetch is unavailable:
# SPOT=6850
# EM=80

# Column index for OD expiration picker (0-based). Usually auto-detected
# by --date flag. Override only if auto-detection fails.
# COLUMN_INDEX=1

# Where to save extracted JSON (relative to repo root)
OUTPUT_PATH=./latest_data.json
